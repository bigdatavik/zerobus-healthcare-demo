bundle:
  name: zerobus-healthcare-demo

# =============================================================================
# VARIABLES - Configure these for your environment
# =============================================================================
variables:
  # Unity Catalog location
  catalog:
    description: "Unity Catalog name"
    default: "my_catalog"  # <-- CHANGE THIS

  schema:
    description: "Schema name"
    default: "zerobus_demo"

  table:
    description: "Table name"
    default: "healthcare_events"

  # Zerobus connection
  # Format: <workspace_id>.zerobus.<region>.cloud.databricks.com
  # Find workspace_id in your URL: https://xxx.cloud.databricks.com/?o=<workspace_id>
  zerobus_server_endpoint:
    description: "Zerobus server endpoint"
    default: "1234567890123456.zerobus.us-east-1.cloud.databricks.com"  # <-- CHANGE THIS

  # Service principal credentials
  # Create with: databricks service-principals create --display-name "zerobus-producer"
  client_id:
    description: "Service principal application ID"
    default: "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # <-- CHANGE THIS

  # Generate with: databricks service-principals secrets create <sp-id>
  client_secret:
    description: "Service principal OAuth secret"
    default: "dosexxxxxxxxxxxxxxxxxxxxxxxxx"  # <-- CHANGE THIS

  # Ingestion settings
  num_records:
    description: "Number of healthcare events to generate per run"
    default: "10"

# =============================================================================
# TARGETS - Configure your workspace
# =============================================================================
targets:
  dev:
    mode: development
    default: true
    workspace:
      host: "https://my-workspace.cloud.databricks.com"  # <-- CHANGE THIS

  prod:
    mode: production
    workspace:
      host: "https://my-workspace.cloud.databricks.com"  # <-- CHANGE THIS (optional)

include:
  - resources/*.yml
